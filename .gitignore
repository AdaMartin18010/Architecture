# =============================================================================
# Architecture Reuse Knowledge Base — Git Ignore
# =============================================================================
# 本项目为软件架构复用知识库（Markdown + Python 工具 + YAML 配置）
# 忽略：依赖环境、编译中间文件、操作系统文件、工具输出
# =============================================================================

# ---------------------------------------------------------------------------
# Python 虚拟环境与依赖
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version
pip-log.txt
pip-delete-this-directory.txt

# ---------------------------------------------------------------------------
# Python 编译中间文件
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ---------------------------------------------------------------------------
# 测试与覆盖率
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ---------------------------------------------------------------------------
# IDE 与编辑器
# ---------------------------------------------------------------------------
.idea/
*.iml
.vscode/settings.json.local
.vscode/*.log
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~
*.bak
*.tmp

# ---------------------------------------------------------------------------
# 操作系统文件
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# 工具运行时输出（应重新生成，不提交）
# ---------------------------------------------------------------------------
*.xlsx          # FinOps / 评估工具生成的 Excel 报告
*.xls
*.pdf           # 导出的 PDF 文档
*.docx          # 导出的 Word 文档
report-*.xlsx
report-*.csv
*.log
# 质量门控、交叉索引、同步等自动生成的报告
reports/*
!reports/.gitkeep

# ---------------------------------------------------------------------------
# Streamlit / Web UI 运行时
# ---------------------------------------------------------------------------
.streamlit/secrets.toml

# ---------------------------------------------------------------------------
# Docker 运行时
# ---------------------------------------------------------------------------
.dockerignore.local

# ---------------------------------------------------------------------------
# 安全敏感（绝不提交）
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets.yaml
secrets.json

# ---------------------------------------------------------------------------
# 临时脚本 / 下载文件
# ---------------------------------------------------------------------------
tmp_*
temp_*
*.download
*.partial
