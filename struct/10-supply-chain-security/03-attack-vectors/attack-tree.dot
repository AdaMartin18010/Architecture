    P6A2 -> P6A2L1;
    P6A2L2 [label="伪造 WiFi 热点
Rogue WiFi Hotspot", fillcolor="#d69e2e", fontcolor="black", penwidth=1, shape=ellipse];
    P6A2 -> P6A2L2;
    P6A2L3 [label="攻陷证书颁发机构
Compromise Certificate Authority", fillcolor="#dd6b20", fontcolor="white", penwidth=2, shape=ellipse];
    P6A2 -> P6A2L3;
    P6 -> P6A2;
    P6A3 [label="[AND] 镜像篡改
Mirror Tampering", fillcolor="#d69e2e", fontcolor="black", penwidth=1, shape=diamond];
    P6A3L1 [label="攻陷官方镜像
