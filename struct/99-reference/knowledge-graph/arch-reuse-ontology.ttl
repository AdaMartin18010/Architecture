@prefix ar: <https://github.com/AdaMartin18010/Architecture/kg/> .
@prefix aro: <https://github.com/AdaMartin18010/Architecture/kg/ontology/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ar:ontology a owl:Ontology ;
    dct:created "2026-07-11T22:24:10.688751+00:00" ;
    dct:description "Ontology for software architecture reuse knowledge base" ;
    dct:title "Architecture Reuse Knowledge Graph Ontology" .

aro:Axiom a owl:Class ;
    rdfs:label "形式化公理" ;
    rdfs:subClassOf aro:Entity .

aro:CaseStudy a owl:Class ;
    rdfs:label "正向或反例案例" ;
    rdfs:subClassOf aro:Entity .

aro:Organization a owl:Class ;
    rdfs:label "组织或厂商" ;
    rdfs:subClassOf aro:Entity .

aro:Protocol a owl:Class ;
    rdfs:label "协议规范" ;
    rdfs:subClassOf aro:Entity .

aro:Specification a owl:Class ;
    rdfs:label "形式化规约工件（TLA+/Alloy/Rego 等）" ;
    rdfs:subClassOf aro:Entity .

aro:Theorem a owl:Class ;
    rdfs:label "定理或命题" ;
    rdfs:subClassOf aro:Entity .

aro:belongsTo a owl:ObjectProperty ;
    rdfs:label "属于主题" ;
    rdfs:domain aro:File ;
    rdfs:range aro:Topic .

aro:context a owl:DatatypeProperty ;
    rdfs:label "上下文" ;
    rdfs:domain aro:Entity ;
    rdfs:range xsd:string .

aro:defines a owl:ObjectProperty ;
    rdfs:label "定义" ;
    rdfs:domain aro:File ;
    rdfs:range aro:Term .

aro:evolvedFrom a owl:ObjectProperty ;
    rdfs:label "演进自（标准/协议版本谱系，端点须为 Standard 或 Protocol，由 kg-shacl-validate.py C6 约束）" ;
    rdfs:domain aro:Entity ;
    rdfs:range aro:Entity .

aro:implementedBy a owl:ObjectProperty ;
    rdfs:label "由工具实现" ;
    rdfs:domain aro:Entity ;
    rdfs:range aro:Tool .

aro:mentions a owl:ObjectProperty ;
    rdfs:label "提及标准" ;
    rdfs:domain aro:File ;
    rdfs:range aro:Standard .

aro:providesNegativeExample a owl:ObjectProperty ;
    rdfs:label "提供反例" ;
    rdfs:domain aro:File ;
    rdfs:range aro:Term .

aro:providesPositiveExample a owl:ObjectProperty ;
    rdfs:label "提供正向示例" ;
    rdfs:domain aro:File ;
    rdfs:range aro:Term .

aro:references a owl:ObjectProperty ;
    rdfs:label "引用（内部链接）" ;
    rdfs:domain aro:File ;
    rdfs:range aro:File .

aro:relatedTo a owl:ObjectProperty ;
    rdfs:label "相关" ;
    rdfs:domain aro:Term ;
    rdfs:range aro:Entity .

aro:sourceFile a owl:DatatypeProperty ;
    rdfs:label "来源文件" ;
    rdfs:domain aro:Entity ;
    rdfs:range xsd:string .

aro:sourceLine a owl:DatatypeProperty ;
    rdfs:label "来源行号" ;
    rdfs:domain aro:Entity ;
    rdfs:range xsd:integer .

aro:Standard a owl:Class ;
    rdfs:label "国际/行业标准或框架" ;
    rdfs:subClassOf aro:Entity .

aro:Tool a owl:Class ;
    rdfs:label "工具、脚本或平台" ;
    rdfs:subClassOf aro:Entity .

aro:Topic a owl:Class ;
    rdfs:label "知识主题，如 01-meta-model-standards" ;
    rdfs:subClassOf aro:Entity .

aro:Term a owl:Class ;
    rdfs:label "术语或概念" ;
    rdfs:subClassOf aro:Entity .

aro:File a owl:Class ;
    rdfs:label "Markdown 源文件" ;
    rdfs:subClassOf aro:Entity .

aro:Entity a owl:Class ;
    rdfs:label "实体" .

