flowchart TB
    subgraph "协议与接口层"
        MCP["MCP 2025-11-25<br/>Tool / Resource / Prompt"]
        A2A["A2A v1.0<br/>Agent Card / Task / Artifact"]
        REST["REST / OpenAPI<br/>同步请求-响应"]
