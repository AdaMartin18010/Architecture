        EVT["Event / Message<br/>异步事件流"]
        GRAPHQL["GraphQL<br/>客户端驱动查询"]
    end

    subgraph "复用单元粒度"
        FUNC["纯函数<br/>无副作用 / 可测试"]
        TOOL["Tool 函数<br/>MCP 可调用工具"]
        RES["Resource 资源<br/>只读数据引用"]
        PROMPT["Prompt 模板<br/>少样本 / 系统提示"]
        AGENT["Agent Card<br/>能力声明与端点"]
        TASK["Task 任务定义<br/>输入-输出契约"]
        WORKFLOW["工作流编排<br/>DAG / 状态机"]
    end

    subgraph "运行时执行"
        LLM["LLM 推理引擎<br/>模型加载 / 批处理"]
