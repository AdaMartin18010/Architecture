        WF_E["工作流执行<br/>Temporal / Windmill"]
        FUNC_R["函数运行时<br/>WebAssembly / V8"]
    end

    subgraph "质量保障"
        TEST["单元测试<br/>属性测试 / 模糊测试"]
        MOCK["Mock / Stub<br/>依赖隔离"]
        CONT_I["契约测试<br/>Pact / Bi-directional"]
        PERF["性能基准<br/>延迟 / 吞吐 / 内存"]
    end

    MCP --> TOOL
    MCP --> RES
    MCP --> PROMPT
