    GRAPHQL --> RES
    FUNC --> LLM
    TOOL --> LLM
    TASK --> ORCH
    WORKFLOW --> WF_E
    FUNC --> FUNC_R
    AGENT --> ORCH
    LLM --> TEST
    FUNC_R --> MOCK
    ORCH --> CONT_I
    WF_E --> PERF

